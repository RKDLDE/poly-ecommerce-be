<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.springbootex.ecommerce.category.query.mapper.CategoryMapper">
    <select id="findAll" resultType="kr.co.springbootex.ecommerce.category.query.dto.CategoryDTO">
        SELECT
            nb_category,
            nb_parent_category,
            nm_category,
            cn_level,
            cn_order
        FROM tb_category
    </select>
</mapper>