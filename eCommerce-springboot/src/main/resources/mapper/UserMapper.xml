<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.springbootex.ecommerce.mapper.UserMapper">
    <select id="findAll" resultType="kr.co.springbootex.ecommerce.dto.UserResponseDto">
        SELECT
            id,
            name,
            email
        FROM e_users
    </select>

    <select id="findById" parameterType="long" resultType="kr.co.springbootex.ecommerce.dto.UserResponseDto">
        SELECT
            id,
            name,
            email
        FROM e_users
        WHERE id= #{id}
    </select>
</mapper>