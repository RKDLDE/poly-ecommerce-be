<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.springbootex.ecommerce.user.query.mapper.UserMapper">
    <select id="findAll" parameterType="kr.co.springbootex.ecommerce.user.query.dto.UserRequestDTO" resultType="kr.co.springbootex.ecommerce.user.query.dto.UserResponseDTO">
        SELECT
        id_user,
        nm_user,
        no_mobile,
        nm_email,
        st_status,
        cd_user_type
        FROM tb_user
        <where>
            <if test="stStatus != null and stStatus != ''">
                AND st_status = #{stStatus}
            </if>
        </where>
        ORDER BY id_user DESC
    </select>
</mapper>